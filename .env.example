# Penlearn environment — copy to .env.local and fill in.

NEXT_TELEMETRY_DISABLED=1

# Email-capture form endpoint for the lesson-footer + book-launch list.
# Paste the form ACTION URL from your provider:
#   - Kit (ConvertKit): the form's "Share → HTML" action URL
#   - Buttondown: https://buttondown.com/api/emails/embed-subscribe/<your-username>
# Until this is set, the signup form renders but the submit button stays disabled
# (so a signup can never be silently dropped). The form posts an `email` field and
# a `_gotcha` honeypot.
NEXT_PUBLIC_NEWSLETTER_ENDPOINT=
